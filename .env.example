# API Configuration
# Copy this file to .env.local and fill in your values

# 1. 小馨宝聊天 API（核心对话功能）
# 服务端变量，不会暴露给客户端
CHAT_API_URL=https://admin.xiaoyibao.com.cn/api/v1/chat/completions
CHAT_API_KEY=your_chat_api_key_here

# 2. 语音合成供应商
# 可选：alibaba / doubao
TTS_PROVIDER=alibaba
TTS_FETCH_TIMEOUT_MS=45000

# 2a. 阿里云 DashScope（语音功能）
ALIBABA_API_KEY=your_alibaba_api_key_here
ALIBABA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 阿里云模型配置
ALIBABA_STT_MODEL=paraformer-v1
ALIBABA_TTS_MODEL=qwen3-tts-flash
ALIBABA_TTS_VOICE=loongbella

# 2b. 豆包 TTS（仅服务端使用，禁止写成 NEXT_PUBLIC_*）
DOUBAO_TTS_APP_ID=your_doubao_app_id_here
DOUBAO_TTS_ACCESS_KEY=your_doubao_access_token_here
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0
DOUBAO_TTS_SPEAKER=zh_female_cancan_mars_bigtts
DOUBAO_TTS_MODEL=
DOUBAO_TTS_FORMAT=mp3
DOUBAO_TTS_SAMPLE_RATE=24000
