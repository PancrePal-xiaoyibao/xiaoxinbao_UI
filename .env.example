# API Configuration
# Copy this file to .env.local and fill in your values

# 1. 小馨宝聊天 API（核心对话功能）
# 服务端变量，不会暴露给客户端
CHAT_API_URL=https://admin.xiaoyibao.com.cn/api/v1/chat/completions
CHAT_API_KEY=your_chat_api_key_here

# 2. 阿里云 DashScope（语音功能）
ALIBABA_API_KEY=your_alibaba_api_key_here
ALIBABA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型配置
ALIBABA_STT_MODEL=paraformer-v1
ALIBABA_TTS_MODEL=qwen3-tts-flash
ALIBABA_TTS_VOICE=loongbella
