# Go Backend Environment
# Copy to backend/.env or export into the Go process environment.

BACKEND_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000

# Chat upstream
CHAT_API_URL=https://admin.xiaoyibao.com.cn/api/v1/chat/completions
CHAT_API_KEY=your_chat_api_key_here

# Speech providers
STT_PROVIDER=alibaba
TTS_PROVIDER=alibaba
STT_REQUEST_TIMEOUT_MS=45000
TTS_FETCH_TIMEOUT_MS=45000

# Alibaba speech
ALIBABA_API_KEY=your_alibaba_api_key_here
ALIBABA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIBABA_STT_MODEL=paraformer-v1
ALIBABA_TTS_MODEL=qwen3-tts-flash
ALIBABA_TTS_VOICE=loongbella

# Doubao STT
DOUBAO_STT_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
DOUBAO_STT_APP_ID=your_doubao_stt_app_id_here
DOUBAO_STT_ACCESS_KEY=your_doubao_stt_access_token_here
DOUBAO_STT_RESOURCE_ID=volc.seedasr.sauc.duration
DOUBAO_STT_MODEL_NAME=bigmodel
DOUBAO_STT_LANGUAGE=zh-CN
DOUBAO_STT_ENABLE_ITN=true
DOUBAO_STT_ENABLE_PUNC=true
DOUBAO_STT_ENABLE_DDC=false
DOUBAO_STT_ENABLE_NONSTREAM=true
DOUBAO_STT_SHOW_UTTERANCES=true
DOUBAO_STT_RESULT_TYPE=full
DOUBAO_STT_END_WINDOW_SIZE=800
DOUBAO_STT_FORCE_TO_SPEECH_TIME=1000

# Doubao TTS
DOUBAO_TTS_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional/sse
DOUBAO_TTS_APP_ID=your_doubao_tts_app_id_here
DOUBAO_TTS_ACCESS_KEY=your_doubao_tts_access_key_here
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0
DOUBAO_TTS_SPEAKER=zh_female_cancan_mars_bigtts
DOUBAO_TTS_MODEL=
DOUBAO_TTS_FORMAT=mp3
DOUBAO_TTS_SAMPLE_RATE=24000
